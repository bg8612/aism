APP_NAME=AISM Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://aism_app:replace_me@127.0.0.1:5432/aism_db

BOT_NAME=AISM Bot
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_MODE=polling
TELEGRAM_POLL_TIMEOUT_SEC=30
TELEGRAM_POLL_LIMIT=20
TELEGRAM_MIN_REPLY_DELAY_SEC=6.0
TELEGRAM_WAITING_INDICATOR_DELAY_SEC=0.8
TELEGRAM_WAITING_INDICATOR_FRAME_SEC=0.9
TELEGRAM_UPDATE_DEDUPE_TTL_SEC=300
# Backward-compatible alias for older env naming:
TELEGRAM_UPDATE_GUARD_TTL=300
TELEGRAM_WEBHOOK_SECRET=replace_me
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_START_MESSAGE=Привет! Это бот компании. Напишите ваш вопрос по услугам, ценам, записи, адресу, графику работы или контактам, и я помогу.

OPENROUTER_API_KEY=replace_me
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=AISM Bot
OPENROUTER_APP_URL=https://openrouter.ai
OPENROUTER_TEMPERATURE=0.3
OPENROUTER_CONTEXT_MESSAGE_LIMIT=6
OPENROUTER_MEMORY_NOTE_LIMIT=8
OPENROUTER_MEMORY_SCAN_MESSAGE_LIMIT=40
OPENROUTER_BUSINESS_KNOWLEDGE_LIMIT=5
OPENROUTER_BUSINESS_KNOWLEDGE_CHARS_PER_BLOCK=900
OPENROUTER_SYSTEM_PROMPT=Ты русскоязычный ассистент Telegram-бота. Отвечай только на русском языке. Пиши кратко и по делу, без служебных тегов, XML/JSON, кода и лишнего шума.

ADMIN_API_TOKEN=change_me
